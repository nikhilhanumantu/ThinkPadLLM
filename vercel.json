{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "public/upload.html" },
    { "source": "/login", "destination": "public/login.html" },
    { "source": "/processing", "destination": "public/previews.html" },
    { "source": "/workspace/:id", "destination": "public/main.html" },
    { "source": "/api/(.*)", "destination": "api/index.py" }
  ]
}
